{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "tui": {
    "$schema": "https://opencode.ai/tui.json",
    "theme": "tokyonight"
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "external_directory": "ask",
    "doom_loop": "deny",
    "question": "allow"
  },
  "default_agent": "plan"
}
